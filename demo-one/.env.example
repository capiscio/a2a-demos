# CapiscIO Demo One — "Zero to Enforcement"
# Copy this file to .env and fill in your credentials.
#
# Get your API key and server ID from the CapiscIO dashboard:
#   https://dev.app.capisc.io
#
# After the RFC-005 release to production, change the URL to:
#   CAPISCIO_SERVER_URL=https://registry.capisc.io

# ── Registry (required) ──────────────────────────────────────────────────
CAPISCIO_API_KEY=sk_live_...
CAPISCIO_SERVER_URL=https://dev.registry.capisc.io

# ── MCP Server identity (required) ───────────────────────────────────────
# Create an MCP Server in the dashboard → MCP Servers → New Server
CAPISCIO_SERVER_ID=<uuid-from-dashboard>

# ── Agent names (optional — auto-generated if omitted) ───────────────────
CAPISCIO_TRUSTED_AGENT_NAME=demo-trusted-agent
CAPISCIO_UNTRUSTED_AGENT_NAME=demo-untrusted-agent

# CapiscIO Demo Two — Policy as Code
#
# Copy to .env and fill in your values.
# All credentials come from your CapiscIO dashboard.

# ── Registry ─────────────────────────────────────────────
# Dev environment (RFC-005 features enabled)
CAPISCIO_SERVER_URL=https://dev.registry.capisc.io

# ── Authentication ───────────────────────────────────────
# API key for agent registration & badge issuance
CAPISCIO_API_KEY=your-api-key-here

# ── MCP Server identity ─────────────────────────────────
# UUID of the registered MCP server (from dashboard)
CAPISCIO_SERVER_ID=your-server-id-here

# ── Policy setup (admin only) ───────────────────────────
# Organization ID (from dashboard URL: /orgs/<id>)
CAPISCIO_ORG_ID=your-org-id-here

# Temporary Clerk JWT for policy creation (short-lived)
# Generate via: dashboard → Developer → API Tokens
# ⚠️  Do NOT commit this value — it grants admin access.
CAPISCIO_ADMIN_JWT=

# CapiscIO MCP Server — environment variables
#
# Copy to .env and fill in your values:
#   cp server/.env.example server/.env

# UUID of this MCP server (create one at https://app.capisc.io)
CAPISCIO_SERVER_ID=<uuid-from-dashboard>

# Registry API key (Settings → API Keys in the dashboard)
CAPISCIO_API_KEY=sk_live_EXAMPLE_REPLACE_ME

# Registry URL (default — no need to change for most users)
CAPISCIO_SERVER_URL=https://registry.capisc.io

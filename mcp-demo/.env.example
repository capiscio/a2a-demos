# CapiscIO MCP Demo — environment variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Then start the demo:
#   docker compose up

# ── Server identity (for the MCP server container) ──────────────────────────

# UUID of the MCP server created in the CapiscIO dashboard, or 'auto' to auto-create
CAPISCIO_SERVER_ID=auto

# Registry API key (from Settings → API Keys in the dashboard)
CAPISCIO_API_KEY=sk_live_...

# ── Agent identity (for the client container) ────────────────────────────────

# Optional: agent badge for the client (enables tools with min_trust_level > 0)
CAPISCIO_AGENT_BADGE=

# Minimum trust level to require from the MCP server (0 = any)
# Note: auto-created servers start at trust level 0 (UNVERIFIED_ORIGIN)
CAPISCIO_MIN_TRUST_LEVEL=0

# ── Infrastructure ────────────────────────────────────────────────────────────

# Override to point at a local capiscio-server instead of production
CAPISCIO_SERVER_URL=http://capiscio-server:8080

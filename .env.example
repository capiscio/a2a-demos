# ═══════════════════════════════════════════════════════════════
# A2A DEMOS CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ───────────────────────────────────────────────────────────────
# LLM Configuration (required for all agents)
# ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ───────────────────────────────────────────────────────────────
# CAPISCIO REGISTRY
# Sign up free at https://app.capisc.io
# ───────────────────────────────────────────────────────────────
CAPISCIO_SERVER_URL=https://registry.capisc.io
CAPISCIO_API_KEY=sk_live_EXAMPLE_REPLACE_ME

# Security mode: "ca" for CA-signed badges
SECURITY_MODE=ca

# Agent IDs are auto-created by the SDK on first connect.
# You do NOT need to set them manually.

# ───────────────────────────────────────────────────────────────
# AGENT PORTS (for HTTP server mode)
# ───────────────────────────────────────────────────────────────
LANGCHAIN_AGENT_PORT=8001
CREWAI_AGENT_PORT=8002
LANGGRAPH_AGENT_PORT=8003

# ───────────────────────────────────────────────────────────────
# SECURITY ENFORCEMENT (optional, all have sensible defaults)
# ───────────────────────────────────────────────────────────────

# Require valid badges on incoming A2A requests (default: false)
# CAPISCIO_REQUIRE_SIGNATURES=false

# What to do when security check fails: "block", "monitor", or "log"
# CAPISCIO_FAIL_MODE=block

# Minimum trust level required for callers (0-4, default: 0)
# CAPISCIO_MIN_TRUST_LEVEL=0

# Rate limiting (default: enabled, 60 rpm)
# CAPISCIO_RATE_LIMITING=true
# CAPISCIO_RATE_LIMIT_RPM=60
